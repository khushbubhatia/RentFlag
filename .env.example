# Copy to .env.local and fill in (never commit real keys).

# OpenAI
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Or Groq (checked first if set)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# No key: rules + extraction still run. With a key, the model also adds checklist items,
# tour questions, and (when this listing is a poor fit) “where to look instead” search ideas.

# Optional: Firecrawl for URL fetches that need JS rendering (Zillow, StreetEasy, etc.).
# Free tier at https://firecrawl.dev (~500 scrapes/mo, no card). Without this key,
# the URL tab does a plain server fetch and asks the user to paste text when sites block.
FIRECRAWL_API_KEY=
